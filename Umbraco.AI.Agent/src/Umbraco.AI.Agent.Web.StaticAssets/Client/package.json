{
    "name": "@umbraco-ai/agent",
    "version": "0.0.0",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./types/umbraco-ai-agent-public-types.d.ts",
    "exports": {
        ".": {
            "types": "./types/umbraco-ai-agent-public-types.d.ts",
            "import": "./src/index.ts"
        }
    },
    "files": [
        "types/umbraco-ai-agent-public-types.d.ts",
        "README.md"
    ],
    "scripts": {
        "watch": "tsc && vite build --watch",
        "build": "npm run build:api && npm run build:app",
        "build:app": "tsc -p tsconfig.json && vite build",
        "build:api": "tsc -p tsconfig.api.json && (api-extractor run -c api-extractor.json --verbose || exit 0)",
        "generate-client": "node --no-warnings ../../../../scripts/build/generate-openapi.js ai-agent-management"
    },
    "dependencies": {
        "@ag-ui/client": "^0.0.42",
        "@retejs/lit-plugin": "^2.0.7",
        "@umbraco-ai/core": "*",
        "@umbraco-cms/backoffice": "^17.1.0",
        "rete": "^2.0.6",
        "rete-area-plugin": "^2.1.5",
        "rete-auto-arrange-plugin": "^2.0.2",
        "rete-connection-plugin": "^2.0.5",
        "rete-minimap-plugin": "^2.0.3",
        "rete-render-utils": "^2.0.3",
        "rxjs": "^7.8.2"
    },
    "overrides": {
        "rxjs": "^7.8.2"
    },
    "devDependencies": {
        "@hey-api/openapi-ts": "0.85.0",
        "@microsoft/api-extractor": "^7.55.1",
        "chalk": "^5.6.0",
        "cross-env": "^10.0.0",
        "node-fetch": "^3.3.2",
        "typescript": "^5.9.2",
        "vite": "^7.1.3"
    }
}
